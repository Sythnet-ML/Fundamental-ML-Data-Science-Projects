                    scoring='f1',
                    cv= 3,
                    verbose= 3,
                    n_jobs=-1)

rf_grid.fit(X_train, y_train)



print(f"Best Estimator: {rf_grid.best_estimator_}")
print(f"Best Score: {rf_grid.best_score_}")
