  {
   "cell_type": "markdown",
   "id": "9974cfee",
   "metadata": {},
   "source": [
    "## Finding the best K- value"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 108,
   "id": "ee994e6c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "score = []\n",
    "K = list(range(1, 10))\n",
    "\n",
    "for k in K:\n",
    "    temp_knn = Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('model', KNeighborsClassifier(n_neighbors=k))])\n",
    "    \n",
    "    temp_knn.fit(X_train, y_train)\n",
    "    knn_pred = temp_knn.predict(X_test)\n",
    "    \n",
    "    score.append(accuracy_score(y_test, knn_pred, ))\n",
    "\n",
    "best_k = K[np.argmax(score)]\n",
    "fig, ax = plt.subplots(figsize= (10, 6))\n",
    "ax.plot(K , score, marker='x',linestyle= '--', color='green', label= f\"Best K {best_k}\")\n",
    "ax.axvline(best_k, linestyle= '--', color='red', linewidth= 0.4)\n",
    "ax.set_xlabel(\"K\"); ax.set_ylabel(\"Score\")\n",
    "ax.set_title(\"Optimized KNN\")\n",
    "ax.legend()\n",
    "\n",
    "plt.tight_layout();     plt.show()"
   ]
  },
