 "cells": [
  {
   "cell_type": "markdown",
   "id": "e15f826f",
   "metadata": {},
   "source": [
    "# BANKRUPTCY PREDICTION - Model Building and Evaluation\n",
    "\n",
    "train 7 classifiers, run cross-validation ,plot ROC-curve, tune the best performer with `GridSearchCV`"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f091c475",
   "metadata": {},
   "source": [
    "## 1. Import and Load Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "24cdecfd",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt \n",
    "import seaborn as sns \n",
    "\n",
    "from sklearn.model_selection import train_test_split, GridSearchCV, cross_val_score\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.metrics import (accuracy_score,precision_score\n",
    "                            , recall_score, f1_score, confusion_matrix,\n",
    "                            roc_curve, auc, classification_report)\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "from sklearn.tree import DecisionTreeClassifier\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
    "from sklearn.svm import SVC\n",
    "from sklearn.naive_bayes import GaussianNB\n",
    "\n",
    "from utils import *\n",
    "\n",
    "sns.set_style('darkgrid')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ad003b32",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('data\\cleaned_bankrupty.csv')\n",
    "print(df.shape)\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "df54f392",
   "metadata": {},
   "source": [
    "## 2. Split the data to train and test with confirmation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cf8bebe1",
   "metadata": {},
   "outputs": [],
   "source": [
    "X = df.drop(columns='Bankrupt')\n",
    "y = df['Bankrupt']\n",
    "\n",
    "X_train, X_, y_train, y_ = train_test_split(X, y, train_size=0.8, stratify=y, random_state=42)\n",
    "X_test , X_safe, y_test, y_safe = train_test_split(X_, y_, random_state=42, train_size=0.8, )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "78bd4dde",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(f'X_train shape : {X_train.shape}, X_test shape: {X_test.shape}, X_safe shape: {X_safe.shape}')\n",
    "print(f'y_train shape : {y_train.shape}, y_test shape: {y_test.shape}, y_safe shape: {y_safe.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "02baefed",
   "metadata": {},
   "source": [
    "# Model Building - Using Pipeline"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "42579024",
   "metadata": {},
   "source": [
    "## Model's Pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "492ec33f",
   "metadata": {},
   "outputs": [],
   "source": [
    "models = {\n",
    "    'Logistic Regression' : Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('model', LogisticRegression(random_state=42, ))\n",
    "    ]), \n",
    "    \n",
    "    'Decision Tree' : Pipeline([\n",
    "        ('model', DecisionTreeClassifier(max_depth=3, random_state=42))\n",
    "    ]),\n",
    "    \n",
    "    'Random Forest': Pipeline([\n",
    "        ('model', RandomForestClassifier(random_state=42, n_estimators=250, max_depth= 4))\n",
    "    ]),\n",
    "    \n",
    "    'Gradient Boosting' : Pipeline([\n",
    "        ('model', GradientBoostingClassifier(learning_rate=0.01, n_estimators=300, max_depth=4, random_state=42))\n",
    "    ]),\n",
    "    \n",
    "    'KNN' : Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('model', KNeighborsClassifier(n_neighbors= 5))\n",
    "    ]),\n",
    "    \n",
    "    'SVC' : Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('model', SVC(kernel='poly', probability=True, C=2))\n",
    "    ]),\n",
    "    \n",
    "    'GaussianNB' : Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('model', GaussianNB())\n",
    "    ]),\n",
    "}"
   ]
  },
